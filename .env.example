# Gmail OAuth (para Conexiones - ingesta automática)
# Crear en: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Tipo: Web application. Redirect URI: https://zfinances.vercel.app/api/gmail/oauth/callback
GMAIL_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=xxx
GMAIL_OAUTH_REDIRECT_URI=https://zfinances.vercel.app/api/gmail/oauth/callback
